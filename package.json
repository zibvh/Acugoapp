{
  "name": "bixcart-app",
  "version": "1.0.0",
  "description": "Bixcart — Buy and sell. Native app via Capacitor.",
  "private": true,
  "scripts": {
    "backend:install": "cd backend && npm install",
    "backend:start": "cd backend && node server.js",
    "cap:sync": "npx cap sync",
    "cap:open:android": "npx cap open android",
    "cap:open:ios": "npx cap open ios",
    "build:inject-api": "node scripts/inject-api-url.js",
    "build:android": "npm run build:inject-api && npx cap sync android",
    "build:ios": "npm run build:inject-api && npx cap sync ios"
  },
  "dependencies": {
    "@capacitor/android": "^6.0.0",
    "@capacitor/app": "^6.0.0",
    "@capacitor/browser": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "@capacitor/ios": "^6.0.0",
    "@capacitor/push-notifications": "^6.0.0",
    "@capacitor/splash-screen": "^6.0.0",
    "@capacitor/status-bar": "^6.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.0.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
